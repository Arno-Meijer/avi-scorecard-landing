---
import Base from '../layouts/Base.astro';

// Hub order: Advisory first (broader service for everyone not at exit),
// then Exit Readiness (specific flagship), Brief, Index.
const hubs = [
  {
    href: '/advisory',
    eyebrow: 'Service · Ongoing',
    title: 'AI Value Advisory',
    description:
      'Strategy, P&L impact, implementation, oversight. Scaled per client, from a 6-week sprint to fractional advisory. For everyone who is not 12 months from exit.',
    cta: 'See engagements',
    accent: 'service-1',
    iconStroke: '#0D1527',
    iconPath:
      '<polyline points="3,17 9,11 13,15 21,7"/><polyline points="15,7 21,7 21,13"/>',
  },
  {
    href: '/exit-readiness',
    eyebrow: 'Service · 2 weeks',
    title: 'AI Exit Readiness',
    description:
      'A 2-week diagnostic. Five pillars, scored. Indicative multiple impact at the end. For founders 12 to 24 months from exit.',
    cta: 'See the service',
    accent: 'service-2',
    iconStroke: '#1B2540',
    iconPath:
      '<rect x="6" y="4" width="12" height="16" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/>',
  },
  {
    href: '/brief',
    eyebrow: 'Newsletter · Launching Soon',
    title: 'AI Value Brief',
    description:
      'Launching soon. The deals, multiples, and frameworks that explain how AI is actually moving valuations. Written by us. Get on the founding list.',
    cta: 'Join the list',
    accent: 'brief',
    iconStroke: '#0F6E56',
    iconPath:
      '<path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>',
  },
  {
    href: '/value-index',
    eyebrow: 'Benchmark · By Request',
    title: 'AI Value Index',
    description:
      '200+ AI deployments scored on what they actually moved. The index stays private. We walk you through the entries that match your case.',
    cta: 'Book a walkthrough',
    accent: 'index',
    iconStroke: '#854F0B',
    iconPath:
      '<rect x="3" y="6" width="18" height="14" rx="2"/><path d="M8 6V4a4 4 0 0 1 8 0v2"/><circle cx="12" cy="13" r="2.5"/>',
  },
];

const founders = [
  {
    name: 'Christan Doornhof',
    role: 'Co-founder, AI Value Firm',
    bio:
      'Led product and technology assessments in due diligence for tech and SaaS deals at EY-Parthenon. Now works with leadership teams on AI decisions that have real consequences for cost, performance, and accountability. Hands-on experience taking AI from pilot to production where outcomes had to hold up beyond the demo.',
    img: '/images/Christan.jpeg',
    linkedin: 'https://www.linkedin.com/in/christan-doornhof/',
    tags: ['AI Implementation', 'Product & Strategy'],
  },
  {
    name: 'Arno Meijer',
    role: 'Co-founder, AI Value Firm',
    bio:
      'Ran the financial analysis on tech and SaaS due diligence at EY-Parthenon, buy-side and sell-side, building the models buyers rely on to size risk and justify multiples. Applied that same lens as a VC investor, managing a portfolio of several companies, stress-testing unit economics, and advising founders on the numbers that matter.',
    img: '/images/Arno.jpg',
    linkedin: 'https://www.linkedin.com/in/arnomeijer1/',
    tags: ['Valuation & Unit Economics', 'VC & Portfolio'],
  },
];

const callUrl = 'https://cal.com/christan-doornhof-bgrvnw/ai-exit-readiness-review';
---
<Base
  title="AI value is measurable. AI Value Firm."
  description="Advisory, exit readiness, and a private benchmark of AI use cases. For founders and investors."
  current="home"
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-text">
        <div class="eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">AI Value Advisory</span>
        </div>
        <h1 class="display">AI value is <span class="accent">measurable.</span><br />The value never reaches the P&amp;L.</h1>
        <p class="hero-sub">
          Boards stopped buying the hype. So did buyers. AI Value Firm helps founders, PE-backed
          operators, and investors put real numbers on what AI is doing to their business.
        </p>

        <form
          class="hero-signup"
          action="/api/submit"
          method="post"
          aria-label="Join the founding list for the AI Value Brief"
          data-avf-submit
          data-avf-success="On the list. We'll send the first issue when we launch."
        >
          <input type="hidden" name="action" value="landing" />
          <input type="hidden" name="source" value="home-hero" />
          <input type="email" name="email" placeholder="you@company.com" required aria-label="Email address" />
          <button type="submit" class="btn btn-primary">Join the list</button>
          <div class="cf-turnstile" data-sitekey="0x4AAAAAACggX5UqhEOHOx_L" data-size="invisible"></div>
        </form>

        <p class="hero-meta">
          Launching soon. First issue and product updates straight to inbox.
          <span class="meta-sep">·</span>
          <a href="#book">Or book a call →</a>
        </p>
      </div>

      <div class="hero-viz" aria-hidden="true">
        <div class="viz-header">
          <span class="viz-eyebrow">Sample scorecard output</span>
          <span class="viz-rating">B · 60/100</span>
        </div>
        <div class="viz-row">
          <span class="viz-row-label">Revenue Resilience</span>
          <div class="viz-bar"><div class="viz-bar-fill" style="width: 70%;"></div></div>
          <span class="viz-row-score">14/20</span>
        </div>
        <div class="viz-row">
          <span class="viz-row-label">Defensibility &amp; Moat</span>
          <div class="viz-bar"><div class="viz-bar-fill" style="width: 55%;"></div></div>
          <span class="viz-row-score">11/20</span>
        </div>
        <div class="viz-row">
          <span class="viz-row-label">AI Economics</span>
          <div class="viz-bar"><div class="viz-bar-fill amber" style="width: 40%;"></div></div>
          <span class="viz-row-score">8/20</span>
        </div>
        <div class="viz-row">
          <span class="viz-row-label">Operational Leverage</span>
          <div class="viz-bar"><div class="viz-bar-fill" style="width: 75%;"></div></div>
          <span class="viz-row-score">15/20</span>
        </div>
        <div class="viz-row">
          <span class="viz-row-label">Governance</span>
          <div class="viz-bar"><div class="viz-bar-fill" style="width: 60%;"></div></div>
          <span class="viz-row-score">12/20</span>
        </div>
        <div class="viz-divider"></div>
        <div class="viz-result">
          <span class="viz-result-label">Indicative impact</span>
          <span class="viz-result-value">+0.8<span>×</span> ARR</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HUBS -->
  <section id="hubs" class="hubs">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow center">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">Four Ways In</span>
        </div>
        <h2 class="display">Pick the entry that fits <span class="accent">the moment.</span></h2>
        <p>
          Two paid services for when you need ongoing measurement or a verdict.
          Two open assets for when you want to read along.
        </p>
      </div>

      <div class="hubs-row-label">
        <span class="row-label-cell">Services</span>
        <span class="row-label-cell">Insights</span>
      </div>

      <div class="hubs-grid">
        {hubs.map((h) => (
          <a href={h.href} class={`hub-card hub-${h.accent}`}>
            <div class="hub-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={h.iconStroke} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={h.iconPath} />
            </div>
            <span class="hub-eyebrow">{h.eyebrow}</span>
            <h3>{h.title}</h3>
            <p>{h.description}</p>
            <span class="hub-cta">{h.cta} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- THESIS -->
  <section class="why">
    <div class="container">
      <div class="why-grid">
        <div>
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-label">The Thesis</span>
          </div>
          <h2 class="display">AI value is measurable, predictable, and maximisable <span class="accent">if you have the data.</span></h2>
        </div>
        <div class="why-points">
          <div class="why-points-item">
            <div class="why-icon">i</div>
            <div>
              <h4>Multiples, not abstractions</h4>
              <p>Every score we give connects to an indicative revenue multiple. Founders see what AI is doing to enterprise value, not a maturity grade.</p>
            </div>
          </div>
          <div class="why-points-item">
            <div class="why-icon">ii</div>
            <div>
              <h4>Built on real deployments</h4>
              <p>We track what AI actually moved at companies that look like yours. No vendor case studies. No demo theatre.</p>
            </div>
          </div>
          <div class="why-points-item">
            <div class="why-icon">iii</div>
            <div>
              <h4>Operator and investor lens</h4>
              <p>Arno comes from financial stress-testing. Christan from product and ops. Either one alone is incomplete. Together, they catch what DD usually misses.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOUNDERS -->
  <section id="founders" class="founders">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow center">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">Founders</span>
        </div>
        <h2 class="display">Two former EY-Parthenon consultants. <span class="accent">One verdict.</span></h2>
      </div>
      <div class="founders-grid">
        {founders.map((f) => (
          <article class="founder-card">
            <div class="founder-img">
              <img src={f.img} alt={f.name} />
            </div>
            <div class="founder-body">
              <h3>
                {f.name}
                <a class="linkedin-link" href={f.linkedin} target="_blank" rel="noopener" aria-label={`${f.name} on LinkedIn`}>
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
              </h3>
              <span class="founder-role">{f.role}</span>
              <p class="founder-bio">{f.bio}</p>
              <div class="founder-tags">
                {f.tags.map((t) => <span class="tag-pill">{t}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section id="book" class="final-cta">
    <div class="container final-cta-inner">
      <div class="final-cta-mark">✦</div>
      <div class="eyebrow center">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Before You Decide</span>
      </div>
      <h2 class="display">Find out where you stand <span class="accent">before a buyer does.</span></h2>
      <p>
        30-minute discovery call with Arno or Christan. Tell us where you sit and what you are
        trying to figure out. We tell you what we would actually do.
      </p>
      <a class="btn btn-teal" href={callUrl} target="_blank" rel="noopener">Book a call</a>
      <div class="final-cta-after">No email wall. No follow-up spam.</div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    margin-top: var(--nav-height);
    padding: 96px 0 100px;
    position: relative; overflow: hidden;
  }
  .hero-grid {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 64px; align-items: center;
    max-width: var(--container); margin: 0 auto; padding: 0 40px;
  }
  .hero-text h1 { margin: 0 0 24px; }
  .hero-sub {
    font-family: var(--font-serif); font-weight: 400;
    font-size: 19px; color: var(--body-text); line-height: 1.55;
    max-width: 520px; margin-bottom: 32px;
  }
  .hero-signup { display: flex; gap: 8px; max-width: 460px; margin-bottom: 14px; }
  .hero-signup input {
    flex: 1; padding: 14px 18px; border: 1.5px solid var(--border);
    border-radius: var(--radius-pill); font-size: 14px; font-family: inherit; min-width: 0;
    background: var(--card-bg);
  }
  .hero-signup input:focus { outline: none; border-color: var(--teal); }
  .hero-signup button { padding: 14px 26px; font-size: 12px; }
  .hero-meta {
    font-family: var(--font-serif); font-style: italic;
    font-size: 14px; color: var(--muted);
  }
  .hero-meta a {
    color: var(--navy); text-decoration: underline;
    font-style: normal; font-family: var(--font-sans); font-weight: 600;
  }
  .hero-meta a:hover { color: var(--teal); }
  .meta-sep { margin: 0 8px; color: var(--border); }

  /* HERO VISUAL */
  .hero-viz {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px;
    box-shadow: var(--shadow-lg); max-width: 460px; margin-left: auto;
    position: relative;
  }
  .hero-viz::before {
    content: ""; position: absolute; top: -24px; left: -24px;
    width: 70px; height: 70px;
    background: var(--light-teal); border-radius: 50%; z-index: -1;
  }
  .hero-viz::after {
    content: ""; position: absolute; bottom: -18px; right: -18px;
    width: 44px; height: 44px;
    background: var(--light-amber); border-radius: 50%; z-index: -1;
  }
  .viz-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid var(--border);
  }
  .viz-eyebrow {
    font-size: 10px; font-weight: 700; letter-spacing: 2px;
    color: var(--muted); text-transform: uppercase;
  }
  .viz-rating {
    font-size: 11px; font-weight: 700; padding: 4px 10px;
    background: var(--light-teal); color: #0F6E56;
    border-radius: var(--radius-pill); letter-spacing: 0.5px;
  }
  .viz-row {
    display: grid; grid-template-columns: 1fr 100px 36px;
    gap: 12px; align-items: center; margin-bottom: 12px;
  }
  .viz-row-label { font-size: 13px; font-weight: 500; color: var(--navy); }
  .viz-bar { height: 8px; background: var(--soft-bg); border-radius: 4px; overflow: hidden; }
  .viz-bar-fill { height: 100%; background: var(--teal); border-radius: 4px; }
  .viz-bar-fill.amber { background: var(--amber); }
  .viz-row-score { font-size: 13px; font-weight: 700; color: var(--navy); text-align: right; }
  .viz-divider { height: 1px; background: var(--border); margin: 18px 0; }
  .viz-result { display: flex; align-items: baseline; justify-content: space-between; }
  .viz-result-label {
    font-family: var(--font-serif); font-style: italic;
    font-size: 14px; color: var(--muted);
  }
  .viz-result-value {
    font-family: var(--font-serif);
    font-size: 28px; font-weight: 700; color: var(--navy);
    letter-spacing: -0.5px;
  }
  .viz-result-value span { color: var(--teal); font-style: italic; font-weight: 500; }

  /* HUBS — 4 across */
  .hubs { background: var(--soft-bg); }
  .hubs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .hubs-row-label {
    display: grid; grid-template-columns: 2fr 2fr;
    gap: 18px; max-width: var(--container);
    margin: 0 auto 14px;
  }
  .row-label-cell {
    font-family: var(--font-sans);
    font-size: 10px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--muted);
    display: flex; align-items: center; gap: 10px;
  }
  .row-label-cell::before {
    content: ""; width: 18px; height: 1px; background: var(--border);
  }

  .hub-card {
    background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 28px 22px; display: flex; flex-direction: column; gap: 12px;
    box-shadow: var(--shadow); position: relative; overflow: hidden;
    transition: all 0.2s ease;
  }
  .hub-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .hub-icon {
    width: 44px; height: 44px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center; margin-bottom: 4px;
  }
  .hub-card.hub-service-1 { border-top: 4px solid var(--mid-navy); }
  .hub-card.hub-service-1 .hub-icon { background: var(--light-blue); }
  .hub-card.hub-service-2 { border-top: 4px solid var(--navy); }
  .hub-card.hub-service-2 .hub-icon { background: var(--light-blue); }
  .hub-card.hub-brief { border-top: 4px solid var(--teal); }
  .hub-card.hub-brief .hub-icon { background: var(--light-teal); }
  .hub-card.hub-index { border-top: 4px solid var(--amber); }
  .hub-card.hub-index .hub-icon { background: var(--light-amber); }
  .hub-eyebrow {
    font-size: 10px; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; color: var(--muted);
  }
  .hub-card h3 { font-family: var(--font-sans); color: var(--navy); font-size: 19px; line-height: 1.2; }
  .hub-card p { font-size: 14px; flex: 1; line-height: 1.6; }
  .hub-cta { font-weight: 700; color: var(--navy); font-size: 12.5px; margin-top: 6px; letter-spacing: 0.3px; }

  @media (max-width: 1100px) {
    .hubs-grid { grid-template-columns: repeat(2, 1fr); }
    .hubs-row-label { display: none; }
  }
  @media (max-width: 600px) {
    .hubs-grid { grid-template-columns: 1fr; }
  }

  /* THESIS */
  .why-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 64px; align-items: start; }
  .why-grid h2 { margin-top: 0; }
  .why-points { display: grid; gap: 32px; }
  .why-points-item { display: grid; grid-template-columns: 36px 1fr; gap: 20px; align-items: start; }
  .why-icon {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--light-blue); color: var(--navy);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-serif); font-style: italic;
    font-weight: 600; font-size: 14px;
  }
  .why-points h4 { font-family: var(--font-sans); color: var(--navy); font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .why-points p { font-size: 15px; }

  /* FOUNDERS */
  .founders { background: var(--soft-bg); }
  .founders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; max-width: 980px; margin: 0 auto; }
  .founder-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); box-shadow: var(--shadow);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: all 0.2s ease;
  }
  .founder-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .founder-img {
    width: 100%; aspect-ratio: 5/4;
    overflow: hidden; background: var(--soft-bg);
  }
  .founder-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .founder-body {
    padding: 28px;
    display: flex; flex-direction: column; flex: 1;
  }
  .founder-card h3 {
    font-family: var(--font-sans); color: var(--navy);
    font-size: 20px; line-height: 1.2; font-weight: 700;
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 4px;
  }
  .linkedin-link {
    display: inline-flex; align-items: center;
    color: #0A66C2; transition: opacity 0.15s;
  }
  .linkedin-link:hover { opacity: 0.7; }
  .founder-role {
    display: block;
    font-size: 14px; color: var(--teal); font-weight: 600;
    margin-bottom: 18px;
  }
  .founder-bio {
    font-size: 14px; line-height: 1.65;
    margin-bottom: 22px; flex: 1;
  }
  .founder-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag-pill {
    display: inline-block;
    padding: 7px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 12px; font-weight: 500;
    color: var(--navy); white-space: nowrap;
  }

  /* FINAL CTA */
  .final-cta { background: var(--navy); color: #fff; position: relative; overflow: hidden; padding: 120px 0; }
  .final-cta-inner { text-align: center; max-width: 720px; margin: 0 auto; position: relative; z-index: 1; }
  .final-cta-mark {
    font-family: var(--font-serif); font-size: 28px;
    color: var(--teal); margin-bottom: 20px;
  }
  .final-cta .eyebrow { justify-content: center; margin-bottom: 22px; }
  .final-cta .eyebrow-line { background: rgba(255, 255, 255, 0.4); }
  .final-cta .eyebrow-label { color: rgba(255, 255, 255, 0.6); }
  .final-cta h2 { color: #fff; margin-bottom: 24px; }
  .final-cta h2 .accent { color: var(--teal); }
  .final-cta p {
    font-family: var(--font-serif); font-weight: 400;
    color: rgba(255, 255, 255, 0.78); margin: 0 auto 36px;
    font-size: 18px; max-width: 560px; line-height: 1.55;
  }
  .final-cta .btn-teal { padding: 18px 44px; font-size: 13px; }
  .final-cta-after {
    margin-top: 22px;
    font-family: var(--font-serif); font-style: italic;
    font-size: 13px; color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 880px) {
    .hero-grid, .why-grid, .founders-grid {
      grid-template-columns: 1fr; gap: 32px;
    }
    .hero-viz { margin: 0 auto; }
  }
  @media (max-width: 520px) {
    .hero-signup { flex-direction: column; max-width: 360px; }
    .hero-signup button { width: 100%; }
  }
