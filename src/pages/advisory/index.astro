---
import Base from '../../layouts/Base.astro';

const modules = [
  {
    title: 'AI Strategy',
    body:
      'Where to invest, where to wait, where to walk away. Built around your sector, your stage, and the data we have on what actually moves valuation.',
    output: 'A sequenced investment plan with multiple impact estimates per option.',
    iconPath: '<circle cx="12" cy="12" r="3"/><path d="M12 2v6M12 16v6M2 12h6M16 12h6"/>',
  },
  {
    title: 'P&L Impact',
    body:
      'Translating AI work into the numbers a board reviews. Revenue lift, margin contribution, cost-to-serve, headcount-equivalent leverage.',
    output: 'A margin attribution model showing what each AI feature is doing per P&L line.',
    iconPath: '<polyline points="3,17 9,11 13,15 21,7"/><polyline points="15,7 21,7 21,13"/>',
  },
  {
    title: 'Implementation Oversight',
    body:
      'A measurement layer over your AI build. Are the deployments delivering. What needs to change. What gets rolled back at month twelve.',
    output: 'Monthly board-ready reports plus quarterly roll-back / double-down recommendations.',
    iconPath: '<path d="M3 12h4l2-7 4 14 2-7h6"/>',
  },
  {
    title: 'Strategic Reviews',
    body:
      'Periodic deep-dives on AI investments, vendor decisions, build-versus-buy choices. Available on retainer for boards and ICs.',
    output: 'A written verdict per question, with the benchmark data behind it.',
    iconPath: '<circle cx="12" cy="12" r="9"/><path d="M12 6v6l4 2"/>',
  },
];

const formats = [
  {
    name: 'Format · 01',
    title: 'Sprint',
    tagline: 'Decision in six weeks.',
    duration: '6 weeks',
    items: [
      'Single AI question, deep-dive',
      'Build vs buy on a specific use case',
      'Strategy for a new vertical or function',
      'Stress-test of an AI investment thesis',
      'Written deliverable at the end',
    ],
    featured: false,
  },
  {
    name: 'Format · 02',
    title: 'Project',
    tagline: 'Build alongside you.',
    duration: '3 to 6 months',
    items: [
      'Strategy plus implementation oversight',
      'Defined initiative or AI investment',
      'Monthly board updates',
      'Quarterly outcome review',
      'Scoped together on a fit call',
    ],
    featured: true,
  },
  {
    name: 'Format · 03',
    title: 'Fractional',
    tagline: 'On-call discipline.',
    duration: 'Ongoing',
    items: [
      'Available 4 to 8 days a month',
      'Board prep, deal review, vendor decisions',
      'AI questions across a portfolio',
      'Quarterly strategic readout',
      'Three-month minimum, monthly retainer',
    ],
    featured: false,
  },
];

const fitUrl = 'https://cal.com/christan-doornhof-bgrvnw/ai-exit-readiness-review';
---
<Base
  title="AI Value Advisory. AI work that has to pay off."
  description="AI Value Advisory engagements. Strategy, P&L impact, implementation, oversight. Scaled per client, from a 6-week sprint to fractional advisory."
  current="advisory"
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow center">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Service · Ongoing</span>
      </div>
      <h1 class="display">AI work, all the way to the <span class="accent">P&amp;L.</span></h1>
      <p class="hero-sub">
        AI Value Advisory engagements. Strategy, P&amp;L impact, implementation, oversight.
        Scaled to your situation, from a 6-week sprint to ongoing fractional advisory.
        For everyone who is not 12 months from exit.
      </p>
      <div class="hero-ctas">
        <a href={fitUrl} target="_blank" rel="noopener" class="btn btn-primary">Book a fit call</a>
        <a href="#formats" class="btn btn-secondary">See engagement formats</a>
      </div>
    </div>
  </section>

  <section class="modules">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow center">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">What We Work On</span>
        </div>
        <h2 class="display">Four areas, <span class="accent">one measurement lens.</span></h2>
        <p>
          Modular by design. Most engagements pull from two or three areas at once.
          The throughline is the same one we use in DD: every claim has to land in the numbers.
        </p>
      </div>

      <div class="modules-grid">
        {modules.map((m) => (
          <article class="module-card">
            <div class="module-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0D1527" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={m.iconPath} />
            </div>
            <h3>{m.title}</h3>
            <p>{m.body}</p>
            <p class="module-output"><em>Output:</em> {m.output}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="formats" class="formats">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow center">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">Engagement Formats</span>
        </div>
        <h2 class="display">Three shapes. <span class="accent">Same discipline.</span></h2>
        <p>
          Pick what fits your situation. We scope every engagement against a measurable outcome,
          and walk away if the work cannot move a number on a P&amp;L or a multiple.
        </p>
      </div>

      <div class="formats-grid">
        {formats.map((f) => (
          <article class={`format-card ${f.featured ? 'featured' : ''}`}>
            {f.featured && <span class="format-badge">Most common</span>}
            <div class="format-name">{f.name}</div>
            <h3>{f.title}</h3>
            <div class="format-tagline">{f.tagline}</div>
            <div class="format-duration">{f.duration}</div>
            <ul>
              {f.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href={fitUrl} target="_blank" rel="noopener" class="format-cta">Book a fit call →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="who-for">
    <div class="container">
      <div class="who-grid">
        <div>
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-label">Who It Is For</span>
          </div>
          <h2 class="display">Three audiences. <span class="accent">Same need.</span></h2>
        </div>
        <div class="who-list">
          <div class="who-item">
            <div class="who-num">i</div>
            <div>
              <h4>Founders and CEOs (mid-market SaaS)</h4>
              <p>Companies between 5M and 100M ARR who want an AI compass without hiring a consulting team. We sit alongside the leadership team for the duration of the engagement.</p>
            </div>
          </div>
          <div class="who-item">
            <div class="who-num">ii</div>
            <div>
              <h4>PE and VC firms (portfolio support)</h4>
              <p>Investors deploying AI plays across portfolio companies. We standardise the measurement framework and apply it across multiple portcos at once.</p>
            </div>
          </div>
          <div class="who-item">
            <div class="who-num">iii</div>
            <div>
              <h4>C-suite at larger companies (multiple initiatives)</h4>
              <p>Enterprise teams running several AI initiatives in parallel who want an external measurement layer. We work alongside internal AI leadership, not against it.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <div class="final-cta-mark">✦</div>
      <div class="eyebrow center">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Before You Commit</span>
      </div>
      <h2 class="display">Tell us where AI <span class="accent">has to land.</span></h2>
      <p>
        30-minute fit call. We hear what you are trying to do, you hear what we would actually run.
        We confirm fit before either of us scope anything. No pitch.
      </p>
      <a class="btn btn-teal" href={fitUrl} target="_blank" rel="noopener">Book a fit call</a>
      <div class="final-cta-after">No email wall. No follow-up spam.</div>
    </div>
  </section>
</Base>

<style>
  .hero {
    margin-top: var(--nav-height);
    padding: 96px 0 80px; text-align: center;
  }
  .hero-inner { max-width: 820px; margin: 0 auto; padding: 0 40px; }
  .hero-inner h1 { margin: 0 0 24px; }
  .hero-sub {
    font-family: var(--font-serif); font-weight: 400;
    font-size: 19px; color: var(--body-text); line-height: 1.55;
    max-width: 680px; margin: 0 auto 36px;
  }
  .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* MODULES */
  .modules { background: var(--soft-bg); }
  .modules-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
  }
  .module-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 32px;
    box-shadow: var(--shadow);
    display: flex; flex-direction: column; gap: 14px;
    border-top: 4px solid var(--mid-navy);
  }
  .module-icon {
    width: 44px; height: 44px; border-radius: 10px;
    background: var(--light-blue);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 4px;
  }
  .module-card h3 { font-family: var(--font-sans); color: var(--navy); font-size: 19px; }
  .module-card p { font-size: 14.5px; line-height: 1.65; }
  /* Body has a fixed min-height so the Output divider anchors at the
     same vertical position across all four cards, regardless of how
     many lines either body or output ends up wrapping to. */
  .module-card p:not(.module-output) { min-height: 6.6em; }
  .module-output {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--navy);
    padding-top: 14px;
    border-top: 1px solid var(--border);
    line-height: 1.5;
  }
  .module-output em {
    font-style: italic;
    font-weight: 600;
    color: var(--teal);
  }

  /* FORMATS */
  .formats-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .format-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 32px 28px;
    box-shadow: var(--shadow); position: relative;
    display: flex;
    flex-direction: column;
  }
  .format-card.featured { border: 2px solid var(--teal); }
  .format-badge {
    position: absolute; top: -12px; left: 50%;
    transform: translateX(-50%);
    background: var(--teal); color: var(--navy);
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 14px; border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .format-name {
    font-family: var(--font-sans); font-size: 11px; font-weight: 700;
    letter-spacing: 2px; color: var(--muted);
    text-transform: uppercase; margin-bottom: 8px;
  }
  .format-card h3 {
    font-family: var(--font-serif); font-variation-settings: "opsz" 36;
    font-size: 28px; color: var(--navy); margin-bottom: 4px;
    letter-spacing: -0.5px;
  }
  .format-tagline {
    font-family: var(--font-serif); font-style: italic;
    font-size: 16px; color: var(--navy); margin-bottom: 6px;
  }
  .format-duration {
    font-family: var(--font-sans);
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--teal); margin-bottom: 22px;
  }
  /* List grows to fill available height so the Book a fit call CTA
     anchors at the same vertical position across all format cards. */
  .format-card ul { list-style: none; padding: 0; margin: 0 0 24px; flex: 1; }
  .format-card li {
    position: relative; padding-left: 22px;
    font-size: 14px; line-height: 1.6; color: var(--body-text);
    margin-bottom: 10px;
  }
  .format-card li::before {
    content: ""; position: absolute; left: 0; top: 9px;
    width: 6px; height: 6px; background: var(--teal); border-radius: 50%;
  }
  .format-cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 700; font-size: 13px; letter-spacing: 0.3px;
    color: var(--navy);
    padding-top: 16px;
    border-top: 1px solid var(--border);
    width: 100%;
    transition: color 0.15s;
  }
  .format-cta:hover { color: var(--teal); }

  /* WHO IT IS FOR */
  .who-for { background: var(--soft-bg); }
  .who-grid {
    display: grid; grid-template-columns: 1fr 2fr; gap: 64px; align-items: start;
  }
  .who-grid h2 { margin-top: 0; }
  .who-list { display: grid; gap: 24px; }
  .who-item {
    display: grid; grid-template-columns: 36px 1fr; gap: 20px; align-items: start;
  }
  .who-num {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--light-blue); color: var(--navy);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-serif); font-style: italic;
    font-weight: 600; font-size: 14px;
  }
  .who-item h4 { font-family: var(--font-sans); color: var(--navy); font-size: 17px; font-weight: 700; margin-bottom: 6px; }
  .who-item p { font-size: 14.5px; line-height: 1.65; }

  /* FINAL CTA */
  .final-cta { background: var(--navy); color: #fff; padding: 120px 0; }
  .final-cta-inner { text-align: center; max-width: 720px; margin: 0 auto; padding: 0 40px; }
  .final-cta-mark { font-family: var(--font-serif); font-size: 28px; color: var(--teal); margin-bottom: 20px; }
  .final-cta .eyebrow { justify-content: center; margin-bottom: 22px; }
  .final-cta .eyebrow-line { background: rgba(255, 255, 255, 0.4); }
  .final-cta .eyebrow-label { color: rgba(255, 255, 255, 0.6); }
  .final-cta h2 { color: #fff; margin-bottom: 24px; }
  .final-cta h2 .accent { color: var(--teal); }
  .final-cta p {
    font-family: var(--font-serif); font-weight: 400;
    color: rgba(255, 255, 255, 0.78); margin: 0 auto 36px;
    font-size: 18px; max-width: 560px; line-height: 1.55;
  }
  .final-cta .btn-teal { padding: 18px 44px; font-size: 13px; }
  .final-cta-after {
    margin-top: 22px; font-family: var(--font-serif); font-style: italic;
    font-size: 13px; color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 880px) {
    .modules-grid, .formats-grid { grid-template-columns: 1fr; gap: 24px; }
    .who-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
