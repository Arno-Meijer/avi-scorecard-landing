<script is:inline>
  // ===== Email gate handler =====
  (function () {
    var form = document.getElementById('gateForm');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      var input = document.getElementById('gateEmail');
      var errBox = document.getElementById('gateError');
      var email = input.value.trim();
      if (!email) return;

      btn.disabled = true; btn.textContent = 'Loading…';
      errBox.style.display = 'none';

      // Capture lead immediately. Don't block UX on response — reveal scorecard either way.
      var urlParams = new URLSearchParams(window.location.search);
      var payload = {
        action: 'landing',
        source: 'scorecard-gate',
        email: email,
        submission_id: (Date.now().toString(36) + Math.random().toString(36).slice(2, 8)),
        landing_url: window.location.href,
        utm_source: urlParams.get('utm_source') || '',
        utm_medium: urlParams.get('utm_medium') || '',
        utm_campaign: urlParams.get('utm_campaign') || '',
        utm_content: urlParams.get('utm_content') || '',
        utm_term: urlParams.get('utm_term') || ''
      };

      fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).catch(function () { /* ignore — reveal anyway */ });

      // Make email available to the legacy scorecard submit
      window.userEmail = email;

      // Reveal scorecard content
      document.getElementById('emailGate').style.display = 'none';
      document.getElementById('scorecardContent').style.display = 'block';

      // Scroll to first scorecard section
      var first = document.querySelector('.company-bar');
      if (first) first.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  })();
</script>

