---
import Base from '../../layouts/Base.astro';
// Placeholder route. The full v2 scorecard from the existing repo will be migrated
// here in the next phase. Two paths:
//   1. Lift-and-shift: paste the existing scorecard-v2.html body into this file
//      and refactor the form submission to keep using /api/submit.
//   2. Componentise: split the 5-pillar wizard into Astro components and reuse
//      the design tokens. Cleaner, but more work up front.
---
<Base
  title="AI Valuation Impact Scan. 5 to 10 minutes. Indicative multiples at the end."
  description="Find out where you stand on the five pillars and what it means for your indicative valuation. 5 to 10 minutes, free, no login."
  current="exit-readiness"
>
  <section class="placeholder">
    <div class="placeholder-inner">
      <div class="eyebrow center">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Placeholder · Migration Pending</span>
      </div>
      <h1 class="display">The Scorecard <span class="accent">migrates here.</span></h1>
      <p class="placeholder-body">
        The interactive 5-pillar scorecard from the existing site lives at <code>scorecard-v2.html</code>
        in the legacy repo. Next step is to port it into this Astro page so it inherits the shared
        layout, nav, and footer, without breaking the existing <code>/api/submit</code> integration.
      </p>

      <div class="placeholder-note">
        <strong>What ships here in next phase</strong>
        The 5-pillar wizard form. The scoring logic. The result page with indicative multiples.
        The submit handler that posts to <code>/api/submit</code> with <code>action=scorecard</code>
        and continues to flow into Pipedrive via n8n.
      </div>

      <a href="/exit-readiness" class="btn btn-primary">Back to Exit Readiness</a>
    </div>
  </section>
</Base>

<style>
  .placeholder {
    margin-top: var(--nav-height);
    padding: 140px 0 120px;
    text-align: center;
  }
  .placeholder-inner { max-width: 720px; margin: 0 auto; padding: 0 40px; }
  .placeholder h1 { margin: 0 0 24px; }
  .placeholder-body {
    font-family: var(--font-serif); font-weight: 400;
    font-size: 18px; line-height: 1.7; color: var(--body-text);
    max-width: 600px; margin: 0 auto 36px;
  }
  .placeholder-note {
    background: var(--soft-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 24px 28px;
    max-width: 600px; margin: 0 auto 36px;
    text-align: left;
    font-size: 14px; line-height: 1.65; color: var(--body-text);
  }
  .placeholder-note code {
    background: var(--card-bg); padding: 2px 8px; border-radius: 4px;
    font-family: ui-monospace, monospace; font-size: 0.92em; color: var(--navy);
  }
  .placeholder-note strong {
    color: var(--navy); display: block; margin-bottom: 6px;
    font-family: var(--font-sans); font-size: 13px;
    letter-spacing: 0.5px; text-transform: uppercase;
  }
  .placeholder-body code {
    background: var(--soft-bg); padding: 2px 8px; border-radius: 4px;
    font-family: ui-monospace, monospace; font-size: 0.92em; color: var(--navy);
  }
</style>
