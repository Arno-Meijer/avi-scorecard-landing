        id: 'q14', label: 'Q14',
        text: 'IP & vendor contract clarity',
        desc: 'Are your AI vendor contracts and IP agreements buyer-friendly?',
        hint: 'Ambiguous data rights or vendor lock-in will kill a deal. This is a 5-minute fix that saves months of negotiation.',
        scores: [
          { val: 0, desc: 'Never reviewed' },
          { val: 1, desc: 'Aware of risks' },
          { val: 2, desc: 'Partial audit' },
          { val: 3, desc: 'Legal review complete' },
          { val: 4, desc: 'Deal-ready, no surprises' }
        ],
        crit: [
          'Vendor lock-in risk',
          'Can\'t guarantee ownership',
          'Fixable, needs action',
          'Buyer-ready for signing',
          'No due diligence friction'
        ]
      },
      {
        id: 'q15', label: 'Q15',
        text: 'Key-person risk & AI knowledge',
        desc: 'Is your AI knowledge shared across the team or locked with one person?',
        scores: [
          { val: 0, desc: 'One person holds everything' },
          { val: 1, desc: 'Very concentrated' },
          { val: 2, desc: 'Some documentation' },
          { val: 3, desc: 'Documented + cross-trained' },
          { val: 4, desc: 'Fully transferable + repeatable' }
        ],
        crit: [
          'Major deal risk - earnout likely',
          'Buyer will cap the multiple',
          'Mitigated but not resolved',
          'Minimal key-person risk',
          'Clean ownership transition'
        ]
      }
    ]
  }
];

// -- STATE & SCORING --
var state = {};
var urlParams = new URLSearchParams(window.location.search);
var userEmail = urlParams.get('email') || '';
var utmParams = {
  utm_source: urlParams.get('utm_source') || '',
  utm_medium: urlParams.get('utm_medium') || '',
  utm_campaign: urlParams.get('utm_campaign') || ''
};

if (userEmail) {
  var ctaEmail = document.querySelector('.cta-section input[type="email"]');
  if (ctaEmail) ctaEmail.value = userEmail;
}

const RAW_MAX = 12;
const SCALED_MAX = 20;
const TOTAL_QUESTIONS = 15;

function scaleScore(raw) {
  return Math.round((raw / RAW_MAX) * SCALED_MAX);
}

function renderDimensions() {
  let html = '';
  dimensions.forEach(d => {
    html += `
      <div class="dimension-block">
        <div class="dim-header">
          <div class="dim-title-wrap">
            <div class="dim-number">${d.num}</div>
            <h2 class="dim-title">${d.title}</h2>
            <div class="dim-subtitle">${d.subtitle}</div>
          </div>
          <div class="dim-score-badge"><span id="dimScore-${d.id}">0</span><span class="of">/20</span></div>
        </div>
        <div class="dim-color-bar"><div class="fill" id="dimBar-${d.id}"></div></div>
        ${d.moatRef ? renderMoatInline() : ''}
        ${d.questions.map(q => `
          <div class="q-card">
            <div class="q-top">
              <div>
                <div class="q-label">${q.label}</div>
                ${q.desc ? '<div class="q-desc">' + q.desc + '</div>' : ''}
                <div class="q-text">${q.text}</div>
                ${q.hint ? '<div class="q-hint">' + q.hint + '</div>' : ''}
              </div>
              <div class="q-selected-score" id="sel-${q.id}">-</div>
            </div>
            <div class="q-scores">
              ${q.scores.map(s => `
                <button class="score-btn" data-q="${q.id}" data-val="${s.val}" onclick="selectScore('${q.id}', ${s.val}, this)">
                  <span class="score-num">${s.val}</span>
                  <span class="score-desc">${s.desc}</span>
                </button>
              `).join('')}
            </div>
            <div class="q-score-feedback" id="feedback-${q.id}" style="display:none;"></div>
            <div class="q-criteria">
              ${q.crit.map((c, i) => {
                const cls = i === 0 ? 'crit-slate' : i === 1 ? 'crit-red' : i === 2 ? 'crit-yellow' : i === 3 ? 'crit-green' : 'crit-teal';
                return `<div class="crit ${cls}">${c}</div>`;
              }).join('')}
            </div>
          </div>
        `).join('')}
      </div>
    `;
  });
  document.getElementById('dimensionsContainer').innerHTML = html;
}

function renderMoatInline() {
  const layers = [
    { num: 1, name: 'Tool Layer', desc: 'Off-the-shelf AI (GPT wrappers). No moat.' },
    { num: 2, name: 'Workflow Layer', desc: 'AI in processes, custom procedures. Moderate moat.' },
    { num: 3, name: 'Data Layer', desc: 'Proprietary data, feedback loops. Strong moat.' },
    { num: 4, name: 'Model/IP Layer', desc: 'Own models, training data, patents. Very strong.' }
  ];
  return `
    <div class="moat-inline" id="moatInline">
      <div class="moat-inline-header" onclick="toggleMoatRef()">
        <div class="moat-inline-title">AI Defensibility Layers (for Q4-Q6)</div>
        <div class="moat-inline-toggle" id="moatToggle">&#9660; Show</div>
      </div>
      <div class="moat-inline-body collapsed" id="moatInlineBody" style="display:none;">
        ${layers.map(l => `
          <div class="moat-inline-card" data-layer="${l.num}">
            <div class="lvl">${l.num}</div>
            <div class="lvl-name">${l.name}</div>
            <div class="lvl-desc">${l.desc}</div>
          </div>
        `).join('')}
      </div>
    </div>
  `;
}

function toggleMoatRef() {
  const body = document.getElementById('moatInlineBody');
  const toggle = document.getElementById('moatToggle');
  const isCollapsed = body.classList.toggle('collapsed');
  if (isCollapsed) {
    toggle.innerHTML = '&#9660; Show';
    body.style.display = 'none';
  } else {
    toggle.innerHTML = '&#9650; Hide';
    body.style.removeProperty('display');
  }
}

function findQuestion(qId) {
  for (const d of dimensions) {
    for (const q of d.questions) {
      if (q.id === qId) return q;
    }
  }
  return null;
}

function selectScore(qId, val, el) {
  const parent = el.parentElement;
  const feedbackEl = document.getElementById(`feedback-${qId}`);

  if (state[qId] === val) {
    state[qId] = null;
    parent.querySelectorAll('.score-btn').forEach(b => {
      b.classList.remove('active-slate', 'active-red', 'active-yellow', 'active-green', 'active-teal');
    });
    const selEl = document.getElementById(`sel-${qId}`);
    selEl.textContent = '-';
    selEl.classList.remove('scored');
    if (feedbackEl) feedbackEl.style.display = 'none';
    updateAll();
    return;
  }

  state[qId] = val;
  parent.querySelectorAll('.score-btn').forEach(b => {
    b.classList.remove('active-slate', 'active-red', 'active-yellow', 'active-green', 'active-teal');
  });

  let cls = val === 0 ? 'active-slate' : val === 1 ? 'active-red' : val === 2 ? 'active-yellow' : val === 3 ? 'active-green' : 'active-teal';
  el.classList.add(cls);

  const selEl = document.getElementById(`sel-${qId}`);
  selEl.textContent = val;
  selEl.classList.add('scored');

  if (feedbackEl) {
    const q = findQuestion(qId);
    if (q) {
      const scoreObj = q.scores[val];
      const critText = q.crit[val] || '';
      feedbackEl.innerHTML = `<span class="fb-score">${val} - ${scoreObj.desc}</span><span class="fb-crit">${critText}</span>`;
      feedbackEl.style.removeProperty('display');
    }
  }

  updateAll();
}

function updateAll() {
  let total = 0;
  let answered = 0;
  const dimScores = [];

  dimensions.forEach(d => {
    let rawTotal = 0;
    d.questions.forEach(q => {
      if (state[q.id] !== null && state[q.id] !== undefined) {
        rawTotal += state[q.id];
        answered++;
      }
    });
    const scaled = scaleScore(rawTotal);
    dimScores.push({ id: d.id, title: d.title, score: scaled, raw: rawTotal });
    total += scaled;

    document.getElementById(`dimScore-${d.id}`).textContent = scaled;
    const bar = document.getElementById(`dimBar-${d.id}`);
    const pct = (scaled / SCALED_MAX) * 100;
    bar.style.width = pct + '%';
    bar.style.background = scaled <= 7 ? 'var(--red)' : scaled <= 14 ? 'var(--yellow)' : 'var(--teal)';
  });

  document.getElementById('navProgress').textContent = `${answered} / ${TOTAL_QUESTIONS}`;
  document.getElementById('navProgressBar').style.width = ((answered / TOTAL_QUESTIONS) * 100) + '%';
  document.getElementById('totalScore').textContent = total;
  document.getElementById('navScore').textContent = total;

  const warningEl = document.getElementById('incompleteWarning');
  if (answered < TOTAL_QUESTIONS && answered > 0) {
    warningEl.textContent = `${TOTAL_QUESTIONS - answered} question${TOTAL_QUESTIONS - answered > 1 ? 's' : ''} unanswered. Your score may be lower than your actual maturity.`;
  } else {
    warningEl.textContent = '';
  }

  let rating, ratingColor, ratingBg, ratingText;
  if (total >= 80) { rating = 'A - Premium Ready'; ratingColor = 'var(--teal)'; ratingBg = 'var(--light-teal)'; ratingText = 'Your AI practices would withstand buyer scrutiny. Strong position for premium valuation. Focus: document and package for data room.'; }
  else if (total >= 60) { rating = 'B - Investable with Gaps'; ratingColor = 'var(--green)'; ratingBg = 'var(--green-bg)'; ratingText = 'Solid foundation, gaps in 1-2 dimensions. A buyer would still engage but negotiate. Focus: close gaps within 90 days.'; }
  else if (total >= 40) { rating = 'C - Discount Territory'; ratingColor = 'var(--yellow)'; ratingBg = 'var(--yellow-bg)'; ratingText = 'AI activity exists but limited proof of P&L impact. Buyers will cap the multiple. Focus: prove 2-3 use cases with hard numbers.'; }
  else if (total >= 20) { rating = 'D - Earn-out Risk'; ratingColor = 'var(--amber)'; ratingBg = '#FFF3E0'; ratingText = 'Aware of AI but nothing a buyer can underwrite. Value shifts to earn-outs and contingencies. Focus: quick wins with measurable ROI.'; }
  else { rating = 'F - Multiple Compression'; ratingColor = 'var(--red)'; ratingBg = 'var(--red-bg)'; ratingText = 'No credible AI story. Buyers either walk or discount heavily. Urgent: establish baseline metrics and governance.'; }

  const badge = document.getElementById('ratingBadge');
  badge.textContent = rating;
  badge.style.background = ratingBg;
  badge.style.color = ratingColor;
  document.getElementById('ratingDesc').textContent = ratingText;

  const ratingLetter = total >= 80 ? 'A' : total >= 60 ? 'B' : total >= 40 ? 'C' : total >= 20 ? 'D' : 'F';
  document.querySelectorAll('#ratingTable tbody tr').forEach(tr => {
    tr.classList.toggle('active-row', tr.dataset.range === ratingLetter);
  });

  const grid = document.getElementById('dimSummaryGrid');
  grid.innerHTML = dimScores.map((ds, i) => {
    const color = ds.score <= 7 ? 'var(--red)' : ds.score <= 14 ? 'var(--yellow)' : 'var(--teal)';
    const action = ds.score <= 7 ? 'Urgent gap - value at risk' : ds.score <= 14 ? 'Work in progress - focus within 90 days' : 'Strong - document & use as proof point';
    const fullWidth = i === dimScores.length - 1 && dimScores.length % 2 !== 0 ? ' full-width' : '';
    return `<div class="dim-sum-card${fullWidth}">
      <div class="dim-sum-dot" style="background:${color}"></div>
      <div class="dim-sum-info">
        <div class="dim-sum-name">${ds.title}</div>
        <div class="dim-sum-action">${action}</div>
      </div>
      <div class="dim-sum-score">${ds.score}<span class="dim-sum-of">/20</span></div>
    </div>`;
  }).join('');

  // Calculate and render multiple impact (extract numeric scores from dim objects)
  calculateAndRenderImpact(dimScores.map(ds => ds.score), ratingLetter);

  const resultsSection = document.getElementById('resultsSection');
  const gateEl = document.getElementById('showResultsGate');
  const detailedEl = document.getElementById('detailedResults');
  if (gateEl && detailedEl && detailedEl.style.display === 'none') {
    const allAnswered = answered === TOTAL_QUESTIONS;
    resultsSection.style.display = allAnswered ? '' : 'none';
    gateEl.style.display = allAnswered ? 'block' : 'none';
    if (allAnswered) {
      document.getElementById('gateMissing').style.display = 'none';
    }
  }

  document.querySelectorAll('.moat-card').forEach(c => c.classList.remove('active-level'));
  document.querySelectorAll('.moat-inline-card').forEach(c => c.classList.remove('active-level'));
  if (state.q6 !== null && state.q6 !== undefined && state.q6 >= 0) {
    let layer = state.q6 === 0 ? 1 : state.q6 === 1 ? 1 : state.q6 === 2 ? 2 : state.q6 === 3 ? 3 : 4;
    document.querySelectorAll(`.moat-card[data-layer="${layer}"], .moat-inline-card[data-layer="${layer}"]`).forEach(c => c.classList.add('active-level'));
  }
}

const DIM_NAMES = ['Revenue Resilience', 'Defensibility & Moat', 'AI Economics', 'Operational Leverage', 'Governance & Readiness'];

function calculateAndRenderImpact(dimScores, ratingLetter) {
  const ind = INDUSTRIES[document.getElementById('industry_v2').value];
  if (!ind) return;

  const dims = dimScores;
  if (!dims || dims.length !== 5) return;

  const rating = ratingLetter || getRatingFromScore(dims);
  const adj = ADJUSTMENTS[rating];

  const arrRange = document.getElementById('arr_range').value;
  const growthRate = document.getElementById('revenue_growth').value;
  if (!arrRange || !growthRate || !ind.baselines[arrRange]) return;
  const baseline = ind.baselines[arrRange][growthRate];

  if (!baseline) return;

  // Weighted score (normalized to 0–100)
  const weightedRaw = dims.reduce((sum, v, i) => sum + (v * ind.weights[i] * 5), 0);
  const weightedScore = Math.round(weightedRaw);

  // Position within adjustment band
  let bandMin, bandMax;
  if (rating === 'A') { bandMin = 80; bandMax = 100; }
  else if (rating === 'B') { bandMin = 60; bandMax = 79; }
  else if (rating === 'C') { bandMin = 40; bandMax = 59; }
  else if (rating === 'D') { bandMin = 20; bandMax = 39; }
  else { bandMin = 0; bandMax = 19; }

  const bandPosition = Math.min(1, Math.max(0, (weightedScore - bandMin) / (bandMax - bandMin)));
  const adjLow = adj.min + (adj.max - adj.min) * bandPosition * 0.5;
  const adjHigh = adj.min + (adj.max - adj.min) * (0.5 + bandPosition * 0.5);

  const multLow = Math.max(0.5, baseline[0] * (1 + adjLow));
  const multHigh = baseline[1] * (1 + adjHigh);

  // Display multiple range
  document.getElementById('multipleRange').textContent = multLow.toFixed(1) + 'x - ' + multHigh.toFixed(1) + 'x';
  document.getElementById('multipleUnit').textContent = ind.metric;
  const metricWord = ind.metric.includes('EBITDA') ? 'EBITDA' : 'revenue';
  document.getElementById('multipleSubLabel').textContent = 'Indicative ' + metricWord + ' multiple range based on your profile and AI readiness score';

  // Spectrum: SYMMETRIC around baseline
  const baselineMidSpec = (baseline[0] + baseline[1]) / 2;
  const worstPossible = baseline[0] * (1 + ADJUSTMENTS.F.min);
  const bestPossible = baseline[1] * (1 + ADJUSTMENTS.A.max);
  const downRange = baselineMidSpec - worstPossible;
  const upRange = bestPossible - baselineMidSpec;
  const halfRange = Math.max(downRange, upRange) * 1.05;

  const specMin = baselineMidSpec - halfRange;
  const specMax = baselineMidSpec + halfRange;
  const specRange = specMax - specMin;

  const ratingColors = { A: '#00B4D8', B: '#22C55E', C: '#EAB308', D: '#F59E0B', F: '#EF4444' };

  // Baseline range bar
  const blLeft = Math.max(0, ((baseline[0] - specMin) / specRange) * 100);
  const blWidth = Math.max(1.5, ((baseline[1] - baseline[0]) / specRange) * 100);
  const baselineBar = document.getElementById('baselineBar');
  baselineBar.style.left = blLeft + '%';
  baselineBar.style.width = blWidth + '%';

  // Position range bar
  const posLeft = Math.max(0, ((multLow - specMin) / specRange) * 100);
  const posWidth = Math.max(1.5, ((multHigh - multLow) / specRange) * 100);
  const posLine = document.getElementById('posLine');
  posLine.style.left = posLeft + '%';
  posLine.style.width = posWidth + '%';

  const posFill = document.getElementById('posFill');
  posFill.style.left = posLeft + '%';
  posFill.style.width = posWidth + '%';

  // Spectrum axis labels
  document.getElementById('specLbl0').textContent = specMin.toFixed(1) + 'x';
  document.getElementById('specLbl1').textContent = (baselineMidSpec - halfRange * 0.5).toFixed(1) + 'x';
  document.getElementById('specLbl2').textContent = baselineMidSpec.toFixed(1) + 'x';
  document.getElementById('specLbl3').textContent = (baselineMidSpec + halfRange * 0.5).toFixed(1) + 'x';
  document.getElementById('specLbl4').textContent = specMax.toFixed(1) + 'x';

  // Impact cards
  const medianPrivate = ind.medianPrivate;
  const baselineMid = ((baseline[0] + baseline[1]) / 2);
  const baselineEl = document.getElementById('baselineLabel');
  baselineEl.textContent = baseline[0].toFixed(1) + 'x - ' + baseline[1].toFixed(1) + 'x';
  baselineEl.style.color = '#FFFFFF';

  const baselineNote = document.getElementById('baselineNote');
  const metricName = ind.metric.includes('EBITDA') ? 'EBITDA' : 'revenue';
  baselineNote.textContent = 'Indicative ' + metricName + ' multiple range for your size and growth profile';

  const currentMultiple = (multLow + multHigh) / 2;
  const effectivePct = ((currentMultiple - baselineMid) / baselineMid) * 100;
  const posEl = document.getElementById('positionLabel');
  posEl.textContent = multLow.toFixed(1) + 'x - ' + multHigh.toFixed(1) + 'x';
  posEl.style.color = ratingColors[rating] || '#EF4444';

  const posNote = document.getElementById('positionNote');
  const effSign = effectivePct >= 0 ? '+' : '';
  const effStr = effSign + effectivePct.toFixed(0) + '%';
  if (effectivePct >= 25) posNote.textContent = 'After AI premium (' + effStr + ' on baseline)';
  else if (effectivePct >= 5) posNote.textContent = 'After AI uplift (' + effStr + ' on baseline)';
  else if (effectivePct >= -1) posNote.textContent = 'AI is not yet impacting your multiple';
  else if (effectivePct >= -10) posNote.textContent = 'After AI discount (' + effStr + ' on baseline)';
  else posNote.textContent = 'After AI compression (' + effStr + ' on baseline)';

  // Gap to premium
  const premLow = baseline[0] * (1 + ADJUSTMENTS.A.min);
  const premHigh = baseline[1] * (1 + ADJUSTMENTS.A.max);
  const gapLow = Math.max(0, premLow - multLow);
  const gapHigh = Math.max(0, premHigh - multHigh);
  const gapLabel = document.getElementById('gapLabel');
  if (gapHigh < 0.1) {
    gapLabel.textContent = 'You\'re there';
  } else {
    gapLabel.textContent = '+' + gapLow.toFixed(1) + 'x - ' + gapHigh.toFixed(1) + 'x';
  }
  document.getElementById('gapNote').textContent = 'Potential uplift if you reach A-rating';

  // Dimension impact bars
  const dimImpactHTML = dims.map((v, i) => {
    const pct = (v / 20) * 100;
    const barColor = pct >= 70 ? '#22C55E' : pct >= 40 ? '#F59E0B' : '#EF4444';
    const effectColor = pct >= 50 ? '#22C55E' : '#EF4444';

    return `<div class="dim-impact-row">
      <div class="dim-impact-name">${DIM_NAMES[i]}</div>
      <div class="dim-impact-bar-wrap"><div class="dim-impact-bar" style="width:${pct}%;background:${barColor}"></div></div>
      <div class="dim-impact-effect" style="color:${effectColor}">${v}/20</div>
    </div>`;
  }).join('');
  document.getElementById('dimImpactRows').innerHTML = dimImpactHTML;

  // Revenue midpoints for EV gap calculation
  const revMidpoints = { small: 2.5, mid: 12.5, growth: 30 };
  const revMid = revMidpoints[arrRange] || 12.5;
  const isEBITDA = ind.metric.includes('EBITDA');
  const earningsBase = isEBITDA ? revMid * 0.20 : revMid;
  const currentEV = currentMultiple * earningsBase;
  const premMid = (premLow + premHigh) / 2;
  const premiumEV = premMid * earningsBase;
  const evGap = premiumEV - currentEV;
  const metricBase = isEBITDA ? 'EBITDA' : 'ARR';

  const fmtEV = (v) => v >= 1 ? '€' + v.toFixed(0) + 'M' : '€' + (v * 1000).toFixed(0) + 'K';
  const evGapAStr = fmtEV(evGap);

  const medianEV = medianPrivate * earningsBase;
  const evGapMedian = medianEV - currentEV;
  const evGapMedStr = fmtEV(Math.abs(evGapMedian));
  const baselineAboveMedian = baselineMid >= medianPrivate;
  const positionAboveMedian = currentMultiple >= medianPrivate;
  const revStr = '€' + revMid + 'M';

  const baselineEV = baselineMid * earningsBase;
  const aiGapEV = Math.abs(currentEV - baselineEV);
  const aiGapEVStr = fmtEV(aiGapEV);

  // Sort dimensions by weakness
  const dimsSorted = dims.map((v, i) => ({ name: DIM_NAMES[i], score: v, index: i, weight: ind.weights[i] }))
    .sort((a, b) => a.score - b.score);

  const dimFocus = [
    'demonstrate AI-driven retention and pricing power with before-and-after metrics',
    'build defensible moats through proprietary data, integration depth, or switching costs',
    'prove AI unit economics with measurable cost reduction or margin improvement',
    'show operational leverage gains: automation rate, output-per-headcount, attributable margin impact',
    'prepare deal-ready governance: IP documentation, data handling protocols, key-person risk mitigation'
  ];

  const weakest = dimsSorted[0];
  const second = dimsSorted[1];
  const focusLine = ' Your biggest gap is ' + weakest.name + ' (' + weakest.score + '/20): ' + dimFocus[weakest.index] + '. Next priority: ' + second.name + ' (' + second.score + '/20).';

  let verdict = '';
  if (rating === 'A') {
    verdict = 'Your AI readiness would withstand buyer scrutiny. Defensible integration, strong economics, deal-ready governance - this profile commands a full AI premium in the current market. ' +
      'At ~' + revStr + ' ' + metricBase + ', your AI readiness is adding ~' + fmtEV(currentEV - baselineEV) + ' in enterprise value above your baseline. Focus: document and package for the data room.';
  } else {
    const aiGapLine = 'Your AI gap (' + effStr + ') is costing you ~' + aiGapEVStr + ' in enterprise value versus your baseline.';
    const premLine = ' Reaching A-rating would add ~' + evGapAStr + ' versus your current position.';
    const contexts = {
      B: ' A buyer would engage but negotiate on your gaps.',
      C: ' AI is present but a buyer can\'t yet underwrite it as a value driver.',
      D: ' A buyer would shift significant value to earn-outs and contingencies.',
      F: ' Fully exposed to AI disruption with no mitigation. A buyer would deduct the full cost of building AI capabilities post-acquisition.'
    };
    verdict = 'At ~' + revStr + ' ' + metricBase + ': ' + aiGapLine + premLine + contexts[rating];
  }
  document.getElementById('verdictText').textContent = verdict;

  const gapActions = [
    { area: 'Revenue resilience under AI disruption', action: 'Demonstrate AI-driven retention and pricing power with before-and-after metrics. Show buyers that churn is declining and ARPU is growing because of AI, not despite it.' },
    { area: 'Competitive moat strength', action: 'Build defensible moats through proprietary data assets, deep integration lock-in, or high switching costs. Quantify what a competitor would need to replicate your AI advantage.' },
    { area: 'AI unit economics', action: 'Prove AI impact on unit economics with measurable cost reduction or margin improvement per customer. Show the trajectory from pilot to scaled savings.' },
    { area: 'Operational leverage from AI', action: 'Show operational leverage gains: automation rate, output-per-headcount ratio, and attributable margin impact. Buyers want to see AI scaling output without scaling cost.' },
    { area: 'Deal-readiness and governance', action: 'Prepare deal-ready governance: IP documentation, data handling protocols, model audit trails, and key-person risk mitigation. This is what due diligence will scrutinize first.' }
  ];

  const top3 = dimsSorted.slice(0, 3);
  const gapHTML = top3.map((d, i) => {
    const gap = gapActions[d.index];
    return `<div class="gap-item">
      <div class="gap-rank">${i + 1}</div>
      <div class="gap-info">
        <div class="gap-dim">${d.name} <span style="color:var(--muted);font-weight:500;font-size:12px;">(${d.score}/20 - ${gap.area})</span></div>
        <div class="gap-desc">${gap.action}</div>
      </div>
    </div>`;
  }).join('');
  document.getElementById('gapItems').innerHTML = gapHTML;

  document.getElementById('impactSection').style.display = 'block';
}

function getRatingFromScore(dims) {
  const ind = INDUSTRIES[document.getElementById('industry_v2').value];
  if (!ind) return 'C';
  const weightedRaw = dims.reduce((sum, v, i) => sum + (v * ind.weights[i] * 5), 0);
  const score = Math.round(weightedRaw);
  if (score >= 80) return 'A';
  if (score >= 60) return 'B';
  if (score >= 40) return 'C';
  if (score >= 20) return 'D';
  return 'F';
}



['industry_v2', 'arr_range', 'revenue_growth', 'companyName', 'role', 'exitHorizon', 'assessor'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) {
    ['input', 'change', 'blur'].forEach(function(evt) {
      el.addEventListener(evt, function() {
        var msg = document.getElementById('gateMissing');
        if (msg) msg.style.display = 'none';
      });
    });
  }
});

try {
  renderDimensions();
  updateAll();
} catch(e) {
  var c = document.getElementById('dimensionsContainer');
  if (c) c.innerHTML = '<div style="background:#FEF2F2;border:1px solid #EF4444;border-radius:14px;padding:24px;text-align:center;color:#1B2A4A;"><strong>Error loading questions</strong><br><span style="font-size:12px;color:#64748B;">'+e.message+'</span></div>';
}

try {
  document.getElementById('assessDate').valueAsDate = new Date();
} catch(e) {
  document.getElementById('assessDate').value = new Date().toISOString().split('T')[0];
}

function revealResults() {
  function isFieldEmpty(el) {
    if (!el) return true;
    if (el.value && el.value.trim() !== '') return false;
    try { if (el.matches(':-webkit-autofill')) return false; } catch(e) {}
    try { if (el.matches(':autofill')) return false; } catch(e) {}
    return true;
  }

  var requiredFields = [
    { id: 'companyName', label: 'Company' },
    { id: 'industry_v2', label: 'Industry (for Valuation)' },
    { id: 'role', label: 'Role' },
    { id: 'arr_range', label: 'Annual Revenue' },
    { id: 'revenue_growth', label: 'Revenue Growth' },
    { id: 'exitHorizon', label: 'Exit / Funding Horizon' },
    { id: 'assessor', label: 'Your name' }
  ];
  var missing = requiredFields.filter(function(f) {
    return isFieldEmpty(document.getElementById(f.id));
  });
  if (missing.length > 0) {
    var missingEl = document.getElementById('gateMissing');
    missingEl.textContent = 'Please complete: ' + missing.map(function(f) { return f.label; }).join(', ');
    missingEl.style.display = 'block';
    var firstMissing = document.getElementById(missing[0].id);
    if (firstMissing) firstMissing.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  var btn = document.getElementById('showResultsBtn');
  btn.disabled = true;
  btn.textContent = 'Saving...';

  var scores = {};
  dimensions.forEach(function(d) {
    var rawTotal = 0;
    d.questions.forEach(function(q) {
      if (state[q.id] !== null && state[q.id] !== undefined) rawTotal += state[q.id];
    });
    scores[d.id] = scaleScore(rawTotal);
  });

  var total = Object.values(scores).reduce(function(a, b) { return a + b; }, 0);
  var rating, segment;
  if (total >= 80) { rating = 'A - Premium Ready'; segment = 'A'; }
  else if (total >= 60) { rating = 'B - Investable with Gaps'; segment = 'B'; }
  else if (total >= 40) { rating = 'C - Discount Territory'; segment = 'C'; }
  else if (total >= 20) { rating = 'D - Earn-out Risk'; segment = 'D'; }
  else { rating = 'F - Multiple Compression'; segment = 'F'; }

  var scored = [];
  dimensions.forEach(function(d) {
    d.questions.forEach(function(q) {
      if (state[q.id] !== null && state[q.id] !== undefined) {
        scored.push({ label: q.label, text: q.text, dim: d.title, score: state[q.id] });
      }
    });
  });
  scored.sort(function(a, b) { return a.score - b.score; });
  var topRisks = scored.slice(0, 3).map(function(l) { return l.label + ': ' + l.text + ' (' + l.dim + ', ' + l.score + '/4)'; });

  var ctaEmailEl = document.querySelector('.cta-section input[type="email"]');
  var email = window.userEmail || userEmail || (ctaEmailEl ? ctaEmailEl.value.trim() : '');

  // Calculate multiple impact values
  const industryVal = document.getElementById('industry_v2').value;
  const arrVal = document.getElementById('arr_range').value;
  const growthVal = document.getElementById('revenue_growth').value;
  const industryConfig = INDUSTRIES[industryVal];

  let baseline_multiple = 0, adjusted_multiple = 0, ai_adjustment_pct = 0;
  if (industryConfig && arrVal && growthVal) {
    const baseline = industryConfig.baselines[arrVal][growthVal];
    const baselineMid = ((baseline[0] + baseline[1]) / 2);
    const weights = industryConfig.weights;
    let weightedScore = 0;
    dimensions.forEach((d, i) => {
      const dimScore = scores[d.id] || 0;
      const normalized = dimScore / SCALED_MAX;
      weightedScore += normalized * weights[i];
    });
    const adjustment = ADJUSTMENTS[segment];
    baseline_multiple = baselineMid;
    adjusted_multiple = baselineMid * (1 + (adjustment.min + adjustment.max) / 2);
    ai_adjustment_pct = weightedScore * 100;
  }

  var payload = {
    action: 'scorecard',
    lead_source: 'Exit Tool',
    submission_id: crypto.randomUUID ? crypto.randomUUID() : Date.now() + '-' + Math.random().toString(36).substr(2, 9),
    email: email,
    company: document.getElementById('companyName').value.trim(),
    industry: document.getElementById('industry_v2').value.trim(),
    role: document.getElementById('role').value || '',
    arr_range: document.getElementById('arr_range').value || '',
    revenue_growth: document.getElementById('revenue_growth').value || '',
    exitHorizon: document.getElementById('exitHorizon').value || '',
    assessor: document.getElementById('assessor').value.trim(),
    exit_score: total,
    segment: segment,
    rating: rating,
    pillar_revenue: scores.rev || 0,
    pillar_moat: scores.moat || 0,
    pillar_economics: scores.econ || 0,
    pillar_leverage: scores.lever || 0,
    pillar_governance: scores.gov || 0,
    top_risks: topRisks,
    utm_source: utmParams.utm_source,
    utm_medium: utmParams.utm_medium,
    utm_campaign: utmParams.utm_campaign,
    landing_url: document.referrer || '',
    assessment_date: new Date().toISOString(),
    industry_v2: document.getElementById('industry_v2').value || '',
    baseline_multiple: baseline_multiple,
    adjusted_multiple: adjusted_multiple,
    ai_adjustment_pct: ai_adjustment_pct
  };

  var revealed = false;

  function showResults() {
    if (revealed) return;
    revealed = true;
    document.getElementById('showResultsGate').style.display = 'none';
    document.getElementById('detailedResults').style.display = 'block';
    document.getElementById('navPill').style.display = '';
    document.getElementById('detailedResults').scrollIntoView({ behavior: 'smooth', block: 'start' });
    trackEvent('tool_completed', { exit_score: total, segment: segment });
  }

  fetch('/api/submit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).then(function() {
    showResults();
  }).catch(function() {
    showResults();
  });

  setTimeout(function() { showResults(); }, 2000);
}

function trackEvent(eventName, data) {
  if (typeof gtag === 'function') {
    gtag('event', eventName, data);
  }
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: eventName, ...data });
}

document.addEventListener('click', function(e) {
  var link = e.target.closest('.book-call-btn');
  if (link) {
    trackEvent('book_call_clicked', {
      exit_score: document.getElementById('totalScore').textContent,
      source: 'scorecard_results'
    });
  }
});

</script>

</Base>
