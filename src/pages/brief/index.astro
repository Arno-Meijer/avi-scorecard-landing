---
import Base from '../../layouts/Base.astro';

const threads = [
  {
    num: 'i.',
    title: 'AI Value Evidence',
    body: 'Hard data from the AI Value Index. Use case impact, deployment depth, ROI distributions across sectors and functions.',
  },
  {
    num: 'ii.',
    title: 'Strategic Frameworks',
    body: 'Decision frameworks for AI investment, exit prep, and portfolio management. Built from deal work, not slides.',
  },
  {
    num: 'iii.',
    title: 'Implementation Reality',
    body: 'Honest case studies. What worked. What burnt cash. What got rolled back at month twelve and why.',
  },
  {
    num: 'iv.',
    title: 'AI Value Outlook',
    body: 'Trend analysis and market commentary. The signal under the hype. Forward-looking, contrarian where the data supports it.',
  },
];

// Pipeline preview. Replace with real issue archive once issues ship.
const pipeline = [
  { meta: 'Topic 01', headline: 'When does an AI feature actually improve gross margin? Notes from 30 SaaS deals.' },
  { meta: 'Topic 02', headline: 'The hidden AI cost in mid-market SaaS, and what it does to your multiple.' },
  { meta: 'Topic 03', headline: 'Why some AI deployments are silently rolled back at month twelve.' },
  { meta: 'Topic 04', headline: 'How PE buyers score AI in DD. Five pillars.' },
];
---
<Base
  title="AI Value Brief. Weekly read on AI and company valuations."
  description="One email a week. The deals, multiples, and frameworks that explain how AI is actually moving company valuations. Written by us."
  current="brief"
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow center">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Newsletter · Launching Soon</span>
      </div>
      <h1 class="display">AI inside companies. <span class="accent">Once a week.</span></h1>
      <p class="hero-sub">
        One email a week on AI inside companies. The deployments that work, the frameworks
        that travel, the case studies that teach, the trends that matter. Written for the
        people deciding what to back, build, or buy.
      </p>

      <form
        class="hero-signup"
        action="/api/submit"
        method="post"
        aria-label="Join the founding list for the AI Value Brief"
        data-avf-submit
        data-avf-success="On the list. We'll send the first issue when we launch."
      >
        <input type="hidden" name="action" value="landing" />
        <input type="hidden" name="source" value="brief-landing" />
        <input type="email" name="email" placeholder="you@company.com" required aria-label="Email address" />
        <button type="submit" class="btn btn-primary">Join the list</button>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAACggX5UqhEOHOx_L" data-size="invisible"></div>
      </form>
      <p class="hero-meta">
        Free. One email a week, the moment we ship.
      </p>
    </div>
  </section>

  <section class="threads">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow center">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">What To Expect</span>
        </div>
        <h2 class="display">Four threads. <span class="accent">One editorial line.</span></h2>
      </div>

      <div class="threads-grid">
        {threads.map((t) => (
          <article class="thread-card">
            <div class="thread-num">{t.num}</div>
            <h3>{t.title}</h3>
            <p>{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="recent">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow center">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-label">In The Pipeline</span>
        </div>
        <h2 class="display">First topics in <span class="accent">the queue.</span></h2>
        <p>
          What the founding list reads first. The archive builds from there.
        </p>
      </div>

      <div class="issues-list">
        {pipeline.map((i) => (
          <div class="issue-item">
            <span class="issue-meta">{i.meta}</span>
            <span class="issue-headline">{i.headline}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="final-cta-inner">
      <div class="final-cta-mark">✦</div>
      <div class="eyebrow center">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">Founding List</span>
      </div>
      <h2 class="display">Get the first issue <span class="accent">in your inbox.</span></h2>
      <p>
        AI inside companies, every week. The work that pays off, the work that doesn't, and
        the frameworks you can use. Written for the people who decide what gets backed,
        built, or bought.
      </p>
      <form
        class="final-cta-form"
        action="/api/submit"
        method="post"
        aria-label="Join the founding list for the AI Value Brief"
        data-avf-submit
        data-avf-success="On the list. We'll send the first issue when we launch."
      >
        <input type="hidden" name="action" value="landing" />
        <input type="hidden" name="source" value="brief-final-cta" />
        <input type="email" name="email" placeholder="you@company.com" required aria-label="Email address" />
        <button type="submit" class="btn btn-teal">Join the list</button>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAACggX5UqhEOHOx_L" data-size="invisible"></div>
      </form>
      <div class="final-cta-after">Sharp, useful reads on what AI is doing to company value. Straight to your inbox, every week.</div>
    </div>
  </section>
</Base>

<style>
  .hero {
    margin-top: var(--nav-height);
    padding: 96px 0 80px; text-align: center;
  }
  .hero-inner { max-width: 720px; margin: 0 auto; padding: 0 40px; }
  .hero-inner h1 { margin: 0 0 24px; }
  .hero-sub {
    font-family: var(--font-serif); font-weight: 400;
    font-size: 19px; color: var(--body-text); line-height: 1.55;
    max-width: 600px; margin: 0 auto 36px;
  }
  .hero-signup {
    display: flex; gap: 8px; max-width: 480px; margin: 0 auto 16px;
  }
  .hero-signup input {
    flex: 1; padding: 16px 20px; border: 1.5px solid var(--border);
    border-radius: var(--radius-pill); font-size: 14px; font-family: inherit;
    background: var(--card-bg); min-width: 0;
  }
  .hero-signup input:focus { outline: none; border-color: var(--teal); }
  .hero-signup button { padding: 16px 28px; }
  .hero-meta {
    font-family: var(--font-serif); font-style: italic;
    font-size: 14px; color: var(--muted);
  }

  /* THREADS */
  .threads { background: var(--soft-bg); }
  .threads-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
    max-width: 980px; margin: 0 auto;
  }
  .thread-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 32px 28px;
    box-shadow: var(--shadow);
    display: flex; flex-direction: column; gap: 12px;
    border-top: 3px solid var(--teal);
  }
  .thread-num {
    font-family: var(--font-serif); font-style: italic;
    font-size: 13px; color: var(--teal); margin-bottom: 4px;
  }
  .thread-card h3 { font-family: var(--font-sans); color: var(--navy); font-size: 19px; }
  .thread-card p { font-size: 14.5px; line-height: 1.65; }

  /* RECENT ISSUES */
  .issues-list { display: grid; gap: 12px; max-width: 820px; margin: 0 auto; }
  .issue-item {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 26px;
    display: grid; grid-template-columns: 80px 1fr; gap: 24px; align-items: center;
  }
  .issue-meta {
    font-family: var(--font-sans); font-size: 11px; font-weight: 700;
    letter-spacing: 1.2px; color: var(--muted); text-transform: uppercase;
  }
  .issue-headline {
    font-family: var(--font-serif);
    font-size: 17px; color: var(--navy); line-height: 1.4; font-weight: 500;
    font-variation-settings: "opsz" 24;
  }

  /* FINAL CTA */
  .final-cta { background: var(--navy); color: #fff; padding: 120px 0; }
  .final-cta-inner { text-align: center; max-width: 720px; margin: 0 auto; padding: 0 40px; }
  .final-cta-mark { font-family: var(--font-serif); font-size: 28px; color: var(--teal); margin-bottom: 20px; }
  .final-cta .eyebrow { justify-content: center; margin-bottom: 22px; }
  .final-cta .eyebrow-line { background: rgba(255, 255, 255, 0.4); }
  .final-cta .eyebrow-label { color: rgba(255, 255, 255, 0.6); }
  .final-cta h2 { color: #fff; margin-bottom: 24px; }
  .final-cta h2 .accent { color: var(--teal); }
  .final-cta p {
    font-family: var(--font-serif); font-weight: 400;
    color: rgba(255, 255, 255, 0.78); margin: 0 auto 36px;
    font-size: 18px; max-width: 560px; line-height: 1.55;
  }
  .final-cta-form { display: flex; gap: 8px; max-width: 480px; margin: 0 auto; }
  .final-cta-form input {
    flex: 1; padding: 16px 20px; border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-pill); font-size: 14px;
    background: rgba(255,255,255,0.05); color: #fff;
    font-family: inherit; min-width: 0;
  }
  .final-cta-form input::placeholder { color: rgba(255,255,255,0.4); }
  .final-cta-form input:focus { outline: none; border-color: var(--teal); }
  .final-cta-form button { padding: 16px 28px; font-size: 12px; }
  .final-cta-after {
    margin-top: 22px; font-family: var(--font-serif); font-style: italic;
    font-size: 13px; color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 880px) {
    .threads-grid { grid-template-columns: 1fr; gap: 24px; }
    .issue-item { grid-template-columns: 1fr; gap: 8px; padding: 18px 22px; }
  }
  @media (max-width: 520px) {
    .hero-signup, .final-cta-form { flex-direction: column; }
    .hero-signup button, .final-cta-form button { width: 100%; }
  }
</style>
