---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="footer-logo">
        <span class="footer-bar"></span>
        <span class="footer-name">AI Value Firm</span>
      </div>
      <p class="footer-tagline">
        AI Value Advisory. We put real numbers on what AI is doing to company valuations.
      </p>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        <li><a href="/advisory">AI Value Advisory</a></li>
        <li><a href="/exit-readiness">AI Exit Readiness</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Insights</h4>
      <ul>
        <li><a href="/brief">AI Value Brief</a></li>
        <li><a href="/value-index">AI Value Index</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <ul>
        <li><a href="/#founders">Founders</a></li>
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="mailto:hello@aivaluefirm.com">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} AI Value Firm. All rights reserved.</span>
  </div>
</footer>

<style>
  .site-footer {
    background: #08101F;
    color: #fff;
    padding: 64px 0 24px;
    margin-top: 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .footer-bar { width: 4px; height: 28px; background: var(--teal); border-radius: 2px; }
  .footer-name { font-weight: 800; font-size: 16px; letter-spacing: 0.3px; }
  .footer-tagline {
    font-family: var(--font-serif); font-weight: 400;
    color: rgba(255, 255, 255, 0.65); font-size: 14px; line-height: 1.6; max-width: 360px;
  }
  .footer-col h4 {
    font-family: var(--font-sans); color: #fff;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 10px; }
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--teal); }
  .footer-bottom {
    padding-top: 24px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 12px;
  }

  @media (max-width: 880px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
