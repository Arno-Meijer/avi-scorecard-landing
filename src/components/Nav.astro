---
// Shared top navigation. Links cover all four AVF surfaces.
// Order: Advisory first (broader service), then Exit Readiness (specific flagship),
// then Brief, then Index.
const { current = '' } = Astro.props as { current?: string };
const links = [
  { href: '/advisory', label: 'Advisory', key: 'advisory' },
  { href: '/exit-readiness', label: 'Exit Readiness', key: 'exit-readiness' },
  { href: '/brief', label: 'Brief', key: 'brief' },
  { href: '/value-index', label: 'Index', key: 'value-index' },
];
const callUrl = 'https://cal.com/christan-doornhof-bgrvnw/ai-exit-readiness-review';
---
<nav class="site-nav">
  <a href="/" class="nav-brand" aria-label="AI Value Firm">
    <span class="nav-logo"></span>
    <span class="nav-name">
      <span>AI VALUE</span>
      <span>FIRM</span>
    </span>
  </a>
  <ul class="nav-links">
    {links.map((l) => (
      <li><a href={l.href} class:list={[{ active: current === l.key }]}>{l.label}</a></li>
    ))}
  </ul>
  <a href={callUrl} target="_blank" rel="noopener" class="btn btn-primary nav-cta">Book a call</a>
</nav>

<style>
  .site-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(253, 251, 246, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    height: var(--nav-height);
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
  }
  .nav-brand { display: flex; align-items: center; gap: 8px; }
  .nav-logo { width: 4px; height: 32px; background: var(--teal); border-radius: 2px; flex-shrink: 0; }
  .nav-name {
    font-family: var(--font-sans);
    font-weight: 800; font-size: 13px; color: var(--navy);
    line-height: 1.15; letter-spacing: 0.3px;
  }
  .nav-name span { display: block; }
  .nav-links {
    display: flex; gap: 24px; list-style: none;
    margin: 0 auto 0 32px;
  }
  .nav-links a {
    font-family: var(--font-sans);
    font-size: 13.5px; font-weight: 500; color: var(--navy);
    transition: color 0.15s;
    white-space: nowrap;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--teal); }
  .nav-cta { padding: 10px 22px; font-size: 11px; }

  @media (max-width: 880px) {
    .site-nav { padding: 0 20px; }
    .nav-links { display: none; }
  }
</style>
