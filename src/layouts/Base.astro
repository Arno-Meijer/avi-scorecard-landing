---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  current?: string;
}

const {
  title,
  description = 'AI Value Firm. We put real numbers on what AI is doing to company valuations. Advisory, exit readiness diagnostic, weekly Brief, and a private benchmark database.',
  ogImage = '/images/og-image.png',
  current = '',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://aivaluefirm.com').toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Inter (UI/body) + Newsreader (editorial display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400..800;1,6..72,400..600&display=swap"
      rel="stylesheet"
    />

    <!-- Cloudflare Turnstile (bot protection on landing forms) -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Global form submit handler — handles all forms with data-avf-submit -->
    <script is:inline>
      (function () {
        function attach() {
          var forms = document.querySelectorAll('form[data-avf-submit]');
          forms.forEach(function (form) {
            if (form.dataset.avfBound) return;
            form.dataset.avfBound = '1';
            form.addEventListener('submit', function (e) {
              e.preventDefault();
              var btn = form.querySelector('button[type="submit"]');
              var originalLabel = btn ? btn.textContent : '';
              if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }

              var formData = new FormData(form);
              var payload = {};
              formData.forEach(function (v, k) { payload[k] = v; });

              // UTM tracking from URL params
              try {
                var urlParams = new URLSearchParams(window.location.search);
                ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(function (key) {
                  var val = urlParams.get(key);
                  if (val) payload[key] = val;
                });
              } catch (err) { /* URLSearchParams unsupported, skip */ }
              payload.landing_url = window.location.href;

              // Turnstile token
              var tokenInput = form.querySelector('[name="cf-turnstile-response"]');
              if (tokenInput && tokenInput.value) {
                payload.turnstileToken = tokenInput.value;
              }

              // Unique ID for server-side dedup
              payload.submission_id =
                (Date.now().toString(36) + Math.random().toString(36).slice(2, 8));

              fetch('/api/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              })
                .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
                .then(function (result) {
                  if (result.ok) {
                    // Clean up Turnstile widget before form replacement
                    var widget = form.querySelector('.cf-turnstile');
                    if (widget && window.turnstile && window.turnstile.remove) {
                      try { window.turnstile.remove(widget); } catch (err) { /* ignore */ }
                    }
                    showSuccess(form);
                  } else {
                    showError(form, result.data && result.data.error ? result.data.error : 'Something went wrong. Please try again.');
                    if (btn) { btn.disabled = false; btn.textContent = originalLabel; }
                  }
                })
                .catch(function () {
                  showError(form, 'Network error. Please try again.');
                  if (btn) { btn.disabled = false; btn.textContent = originalLabel; }
                });
            });
          });
        }

        function showSuccess(form) {
          var msg = form.dataset.avfSuccess || 'Subscribed. Check your inbox for the next issue.';
          var holder = document.createElement('div');
          holder.className = 'avf-form-success';
          holder.setAttribute('role', 'status');
          holder.textContent = msg;
          form.replaceWith(holder);
        }

        function showError(form, message) {
          var existing = form.querySelector('.avf-form-error');
          if (existing) existing.remove();
          var err = document.createElement('div');
          err.className = 'avf-form-error';
          err.setAttribute('role', 'alert');
          err.textContent = message;
          form.appendChild(err);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attach);
        } else {
          attach();
        }
      })();
    </script>

    <style is:global>
      .avf-form-success {
        max-width: 460px;
        margin: 0 auto 14px;
        padding: 14px 22px;
        background: var(--light-teal, #E8F5F3);
        color: #0F6E56;
        border-radius: var(--radius-pill, 100px);
        font-family: var(--font-sans, 'Inter', sans-serif);
        font-size: 14px; font-weight: 600;
        text-align: center;
      }
      .avf-form-error {
        margin-top: 12px;
        padding: 10px 16px;
        background: #FCEBEB;
        color: #A32D2D;
        border-radius: 10px;
        font-family: var(--font-sans, 'Inter', sans-serif);
        font-size: 13px; font-weight: 500;
      }
    </style>
  </body>
</html>
